# .env.example - commit this file
#
# MONGO_URI — two valid values:
#   mongodb://mongo:27017/       ← Docker Compose (container-to-container, primary mode)
#   mongodb://localhost:27017/   ← local Python dev without Docker
MONGO_URI=mongodb://mongo:27017/
MONGO_DB=restMovies
JWT_SECRET_KEY=replace-with-a-long-random-string
FLASK_PORT=4000
JWT_ACCESS_TOKEN_EXPIRES_HOURS=24
# GRAFANA_ADMIN_PASSWORD — if unset, docker-compose falls back to "admin" (see GF_SECURITY_ADMIN_PASSWORD
# default in docker-compose.yaml). That fallback is acceptable for isolated local dev but must NOT
# be used on any network-accessible deployment.
GRAFANA_ADMIN_PASSWORD=replace-with-strong-password